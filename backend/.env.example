# Aptos/Shelby config used by backend transaction builders.
PORT=3000
APTOS_REST=https://api.testnet.aptoslabs.com/v1
SHELBY_NETWORK=testnet
SHELBY_STORAGE_NETWORK=shelbynet
MODULE_ADDR=0xYOUR_MODULE_ADDRESS
SHELBY_API_KEY=replace_me
# SECURITY: never commit real private keys. Store them in a secret manager.
SHELBY_ACCOUNT_PRIVATE_KEY=replace_me
